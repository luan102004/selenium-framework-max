<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<!-- Bài 4: Chạy 4 luồng song song trên Selenium Grid -->
<!-- mvn test -Dgrid.url=http://localhost:4444 -DsuiteXmlFile=src/test/resources/testng-grid.xml -->
<suite name="Grid Suite" parallel="tests" thread-count="4" verbose="1">
    <listeners>
        <listener class-name="utils.RetryListener"/>
    </listeners>
    <parameter name="env" value="dev"/>
    <test name="Chrome – Login">
        <parameter name="browser" value="chrome"/>
        <classes><class name="tests.LoginTest"/></classes>
    </test>
    <test name="Chrome – Cart">
        <parameter name="browser" value="chrome"/>
        <classes><class name="tests.CartTest"/></classes>
    </test>
    <test name="Firefox – Login">
        <parameter name="browser" value="firefox"/>
        <classes><class name="tests.LoginTest"/></classes>
    </test>
    <test name="Firefox – Cart">
        <parameter name="browser" value="firefox"/>
        <classes><class name="tests.CartTest"/></classes>
    </test>
</suite>
